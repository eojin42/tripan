<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.tripan.mapper.admin.MagazineMapper">

    <!-- ── ResultMap: 아티클 (블록/태그 없이) ── -->
    <resultMap id="articleRM" type="com.tripan.app.admin.domain.dto.MagazineArticleDto">
        <id     property="articleId"   column="article_id"/>
        <result property="category"    column="category"/>
        <result property="layoutType"  column="layout_type"/>
        <result property="title"       column="title"/>
        <result property="summary"     column="summary"/>
        <result property="thumbnailUrl" column="thumbnail_url"/>
        <result property="heroImgUrl"  column="hero_img_url"/>
        <result property="leadText"    column="lead_text"/>
        <result property="status"      column="status"/>
        <result property="pubDate"     column="pub_date"/>
        <result property="sortOrder"   column="sort_order"/>
        <result property="regDate"     column="reg_date"/>
        <result property="modDate"     column="mod_date"/>
    </resultMap>

    <!-- ── ResultMap: 블록 ── -->
    <resultMap id="blockRM" type="com.tripan.app.admin.domain.dto.MagazineBlockDto">
        <id     property="blockId"    column="block_id"/>
        <result property="articleId"  column="article_id"/>
        <result property="blockType"  column="block_type"/>
        <result property="sortOrder"  column="sort_order"/>
        <result property="content"    column="content"/>
        <result property="imageUrl"   column="image_url"/>
        <result property="imageLeft"  column="image_left"/>
        <result property="imageRight" column="image_right"/>
        <result property="citeText"   column="cite_text"/>
    </resultMap>

    <!-- ════════════════════════════════
         아티클 CRUD
    ════════════════════════════════ -->

    <!-- 목록 (관리자용: 전체) -->
    <select id="selectAll" resultMap="articleRM">
        SELECT *
        FROM   magazine_article
        ORDER  BY sort_order ASC, reg_date DESC
    </select>

    <!-- 목록 (프론트용: 게시 중만) -->
    <select id="selectPublished" resultMap="articleRM">
        SELECT *
        FROM   magazine_article
        WHERE  status = 1
        ORDER  BY sort_order ASC
    </select>

    <!-- 단건 조회 -->
    <select id="selectById" parameterType="int" resultMap="articleRM">
        SELECT *
        FROM   magazine_article
        WHERE  article_id = #{articleId}
    </select>

    <!-- 아티클 등록 -->
    <insert id="insertArticle" parameterType="com.tripan.app.admin.domain.dto.MagazineArticleDto"
            useGeneratedKeys="true" keyProperty="articleId">
        INSERT INTO magazine_article
            (category, layout_type, title, summary,
             thumbnail_url, hero_img_url, lead_text,
             status, pub_date, sort_order)
        VALUES
            (#{category}, #{layoutType}, #{title}, #{summary},
             #{thumbnailUrl}, #{heroImgUrl}, #{leadText},
             #{status}, #{pubDate}, #{sortOrder})
    </insert>

    <!-- 아티클 수정 -->
    <update id="updateArticle" parameterType="com.tripan.app.admin.domain.dto.MagazineArticleDto">
        UPDATE magazine_article
        SET
            category     = #{category},
            layout_type  = #{layoutType},
            title        = #{title},
            summary      = #{summary},
            thumbnail_url= #{thumbnailUrl},
            hero_img_url = #{heroImgUrl},
            lead_text    = #{leadText},
            status       = #{status},
            pub_date     = #{pubDate},
            sort_order   = #{sortOrder}
        WHERE article_id = #{articleId}
    </update>

    <!-- 상태만 변경 -->
    <update id="updateStatus">
        UPDATE magazine_article
        SET    status = #{status}
        WHERE  article_id = #{articleId}
    </update>

    <!-- 아티클 삭제 (블록/태그 CASCADE) -->
    <delete id="deleteArticle" parameterType="int">
        DELETE FROM magazine_article WHERE article_id = #{articleId}
    </delete>

    <!-- ════════════════════════════════
         블록 CRUD
    ════════════════════════════════ -->

    <!-- 해당 아티클의 블록 전체 조회 -->
    <select id="selectBlocksByArticleId" parameterType="int" resultMap="blockRM">
        SELECT *
        FROM   magazine_block
        WHERE  article_id = #{articleId}
        ORDER  BY sort_order ASC
    </select>

    <!-- 블록 단건 등록 -->
    <insert id="insertBlock" parameterType="com.tripan.app.admin.domain.dto.MagazineBlockDto"
            useGeneratedKeys="true" keyProperty="blockId">
        INSERT INTO magazine_block
            (article_id, block_type, sort_order,
             content, image_url, image_left, image_right, cite_text)
        VALUES
            (#{articleId}, #{blockType}, #{sortOrder},
             #{content}, #{imageUrl}, #{imageLeft}, #{imageRight}, #{citeText})
    </insert>

    <!-- 해당 아티클 블록 전체 삭제 (재저장 전 정리용) -->
    <delete id="deleteBlocksByArticleId" parameterType="int">
        DELETE FROM magazine_block WHERE article_id = #{articleId}
    </delete>

    <!-- 태그 -->

    <!-- 태그 조회 -->
    <select id="selectTagsByArticleId" parameterType="int" resultType="String">
        SELECT tag_name
        FROM   magazine_tag
        WHERE  article_id = #{articleId}
    </select>

    <!-- 태그 단건 삽입 -->
    <insert id="insertTag">
        INSERT INTO magazine_tag (article_id, tag_name)
        VALUES (#{articleId}, #{tagName})
    </insert>

    <!-- 태그 전체 삭제 (재저장 전 정리용) -->
    <delete id="deleteTagsByArticleId" parameterType="int">
        DELETE FROM magazine_tag WHERE article_id = #{articleId}
    </delete>

</mapper>